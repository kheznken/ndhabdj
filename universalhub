MakeToggle(ItemsPage, "Glide Tool", IC, function(v)
	GlideActive = v
	local hum = Character and Character:FindFirstChildOfClass("Humanoid")
	if v then
		if hum then hum.PlatformStand = true end
		GlideConn = RunService.Heartbeat:Connect(function()
			if not GlideActive then
				if GlideConn then GlideConn:Disconnect() GlideConn = nil end
				local h2 = Character and Character:FindFirstChildOfClass("Humanoid")
				if h2 then h2.PlatformStand = false end
				return
			end
			local rp = Character and Character:FindFirstChild("HumanoidRootPart")
			if rp and Mouse.Hit then
				local dir = (Mouse.Hit.Position - rp.Position).Unit
				rp.AssemblyLinearVelocity = dir * 50
			end
		end)
	else
		if GlideConn then GlideConn:Disconnect() GlideConn = nil end
		if hum then hum.PlatformStand = false end
	end
end)

