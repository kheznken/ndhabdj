RunService.Heartbeat:Connect(function()
	local rp = Character and Character:FindFirstChild("HumanoidRootPart")
	local hum = Character and Character:FindFirstChildOfClass("Humanoid")
	if rp and Settings.AntiFling then
		if rp.AssemblyLinearVelocity.Magnitude > 200 then
			rp.AssemblyLinearVelocity = Vector3.zero
			rp.AssemblyAngularVelocity = Vector3.zero
		end
	end
	if hum and Settings.AntiSit and hum.Sit then hum.Sit = false end
	if hum and Settings.AntiRagdoll then
		local st = hum:GetState()
		if st == Enum.HumanoidStateType.Ragdoll or st == Enum.HumanoidStateType.FallingDown then
			hum:ChangeState(Enum.HumanoidStateType.GettingUp)
		end
	end
	if hum and Settings.AntiStun then
		if hum.WalkSpeed < 4 and hum.WalkSpeed ~= 0 then
			hum.WalkSpeed = 16
		end
	end
end)

