	b.TextSize = 12
	b.BorderSizePixel = 0
	b.Parent = page
	Instance.new("UICorner", b).CornerRadius = UDim.new(0, 7)
	local s = Instance.new("UIStroke", b)
	s.Thickness = 1.8
	s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	MakeGradient(s, col)
	MakeGradient(b, col)
	b.MouseButton1Click:Connect(function()
		state = not state
