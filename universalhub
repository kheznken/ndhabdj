local function MakeGradient(parent, col)
	local lighter = Color3.new(
		math.min(col.R + 0.35, 1),
		math.min(col.G + 0.35, 1),
		math.min(col.B + 0.35, 1)
	)
	local g = Instance.new("UIGradient")
	g.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, col),
		ColorSequenceKeypoint.new(0.5, lighter),
		ColorSequenceKeypoint.new(1, col)
	})
	g.Rotation = 45
	g.Parent = parent
	return g
end

