			local gliding = false
			local conn = nil
			Tool.Activated:Connect(function()
				gliding = not gliding
				local rp = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
				local hum = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
				if gliding then
					if hum then hum.PlatformStand = true end
					conn = RunService.Heartbeat:Connect(function()
						if rp then
							local mouse = game.Players.LocalPlayer:GetMouse()
							local dir = (mouse.Hit.Position - rp.Position).Unit
							rp.Velocity = dir * 40
						end
					end)
				else
					if hum then hum.PlatformStand = false end
					if conn then conn:Disconnect() end
				end
			end)
		]]
		GlideToolObj.Parent = LP.Backpack
	else
		if GlideToolObj then GlideToolObj:Destroy() GlideToolObj = nil end
	end
end)

