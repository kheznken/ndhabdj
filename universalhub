local function getTeamColor(player)
	if player.Team then return player.TeamColor.Color end
	return Color3.fromRGB(255, 255, 255)
end

local function isTeammate(player)
	if not Settings.TeamCheck then return false end
	if LP.Team == nil then return false end
	return player.Team == LP.Team
end

local function cleanEsp(player)
	local data = EspData[player]
	if data then
		if data.highlight and data.highlight.Parent then data.highlight:Destroy() end
		if data.billboard and data.billboard.Parent then data.billboard:Destroy() end
		EspData[player] = nil
	end
end

local function buildEsp(player, character)
	cleanEsp(player)
	local highlight = Instance.new("Highlight")
	highlight.FillTransparency = 0.55
	highlight.OutlineTransparency = 0
	highlight.Enabled = false
	highlight.Parent = character

	local head = character:FindFirstChild("Head")
	local billboard, nameLabel, distLabel, hpFill = nil, nil, nil, nil

	if head then
		billboard = Instance.new("BillboardGui")
		billboard.Size = UDim2.new(0, 140, 0, 58)
		billboard.StudsOffset = Vector3.new(0, 3.5, 0)
		billboard.AlwaysOnTop = true
		billboard.Enabled = false
		billboard.Parent = head

		nameLabel = Instance.new("TextLabel")
		nameLabel.Size = UDim2.new(1, 0, 0, 18)
		nameLabel.Position = UDim2.new(0, 0, 0, 0)
		nameLabel.BackgroundTransparency = 1
		nameLabel.Font = Enum.Font.GothamBold
		nameLabel.TextSize = 13
		nameLabel.TextStrokeTransparency = 0
		nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
		nameLabel.Text = player.Name
		nameLabel.Parent = billboard

		distLabel = Instance.new("TextLabel")
		distLabel.Size = UDim2.new(1, 0, 0, 16)
		distLabel.Position = UDim2.new(0, 0, 0, 19)
		distLabel.BackgroundTransparency = 1
		distLabel.Font = Enum.Font.Gotham
		distLabel.TextSize = 11
		distLabel.TextStrokeTransparency = 0
		distLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
		distLabel.Text = ""
		distLabel.Parent = billboard

		local hpBg = Instance.new("Frame")
		hpBg.Size = UDim2.new(1, 0, 0, 8)
		hpBg.Position = UDim2.new(0, 0, 0, 38)
		hpBg.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
		hpBg.BorderSizePixel = 0
		hpBg.Parent = billboard
		Instance.new("UICorner", hpBg).CornerRadius = UDim.new(0, 4)

		hpFill = Instance.new("Frame")
		hpFill.Size = UDim2.new(1, 0, 1, 0)
		hpFill.BackgroundColor3 = Color3.fromRGB(80, 255, 100)
		hpFill.BorderSizePixel = 0
		hpFill.Parent = hpBg
		Instance.new("UICorner", hpFill).CornerRadius = UDim.new(0, 4)
	end

	EspData[player] = {
		highlight = highlight,
		billboard = billboard,
		nameLabel = nameLabel,
		distLabel = distLabel,
		hpFill = hpFill,
		character = character
	}
end

local function setupEspPlayer(player)
	if player == LP then return end
	local function onChar(char)
		task.delay(0.6, function()
			if char and char.Parent then buildEsp(player, char) end
		end)
	end
	if player.Character then onChar(player.Character) end
	player.CharacterAdded:Connect(onChar)
	player.AncestryChanged:Connect(function()
		if not player.Parent then cleanEsp(player) end
	end)
end

for _, p in pairs(Players:GetPlayers()) do setupEspPlayer(p) end
Players.PlayerAdded:Connect(setupEspPlayer)
Players.PlayerRemoving:Connect(cleanEsp)

RunService.RenderStepped:Connect(function()
	for _, player in pairs(Players:GetPlayers()) do
		if player == LP then continue end
		local data = EspData[player]
		if not data then continue end
		local char = player.Character
		if not char then continue end
		local teammate = isTeammate(player)
		local teamCol = getTeamColor(player)
		local myRoot = Character and Character:FindFirstChild("HumanoidRootPart")
		local theirRoot = char:FindFirstChild("HumanoidRootPart")
		local dist = myRoot and theirRoot and (myRoot.Position - theirRoot.Position).Magnitude or math.huge
		local inRange = dist <= Settings.EspRange
		local show = Settings.EspEnabled and not teammate and inRange

		if data.highlight and data.highlight.Parent then
			data.highlight.Enabled = show
			data.highlight.FillColor = teamCol
			data.highlight.OutlineColor = teamCol
		end

		if data.billboard and data.billboard.Parent then
			local showName = Settings.NameEsp and show
			local showDist = Settings.DistanceEsp and show
			local showHp = Settings.HealthEsp and show
			data.billboard.Enabled = show and (showName or showDist or showHp)

			if data.nameLabel then
				data.nameLabel.Visible = showName
				data.nameLabel.Text = player.Name
				data.nameLabel.TextColor3 = teamCol
			end
			if data.distLabel then
				data.distLabel.Visible = showDist
				data.distLabel.Text = math.floor(dist) .. " studs"
				data.distLabel.TextColor3 = teamCol
			end
			if data.hpFill then
				local hum = char:FindFirstChildOfClass("Humanoid")
				if hum then
					local pct = math.clamp(hum.Health / math.max(hum.MaxHealth, 1), 0, 1)
					data.hpFill.Size = UDim2.new(pct, 0, 1, 0)
					data.hpFill.BackgroundColor3 = Color3.fromRGB(math.floor(255*(1-pct)), math.floor(255*pct), 50)
					data.hpFill.Parent.Parent.Visible = showHp
				end
			end
		end

		if data.character ~= char then buildEsp(player, char) end
	end
end)

